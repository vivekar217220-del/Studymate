}

// ── Subject performance row ───────────────────────────────────────────────────
function SubjectRow({ subjectName, entries }) {
    const avgPct = Math.round(entries.reduce((a, e) => a + e.pct, 0) / entries.length)
    const best = Math.max(...entries.map(e => e.pct))
    const attempts = entries.length
    
    // Sober colors mapping
    const barColor = avgPct >= 80 ? 'bg-slate-800' : avgPct >= 60 ? 'bg-slate-500' : 'bg-slate-300'

    return (
        <div className="bg-white rounded-lg border border-slate-200 p-4 shadow-sm">
            <div className="flex items-center justify-between mb-3">
                <div>
                    <p className="text-slate-900 text-sm font-medium">{subjectName}</p>
                    <p className="text-slate-500 text-xs mt-0.5">{attempts} attempt{attempts !== 1 ? 's' : ''} · Best: {best}%</p>
                </div>
                <span className="text-xs font-medium px-2.5 py-1 rounded border border-slate-200 bg-slate-50 text-slate-700">
                    {avgPct}% avg
                </span>
            </div>
            <div className="w-full bg-slate-100 rounded-full h-1.5">
                <div className={`${barColor} h-1.5 rounded-full transition-all duration-700`}
                    style={{ width: `${avgPct}%` }} />
            </div>
            {/* Last 5 attempts sparkline dots */}
            <div className="flex items-center gap-1.5 mt-3">
                {entries.slice(-5).map((e, i) => (
                    <div key={i} title={`${e.pct}% on ${e.date}`}
                        className={`w-1.5 h-1.5 rounded-full ${e.pct >= 80 ? 'bg-slate-800' : e.pct >= 60 ? 'bg-slate-500' : 'bg-slate-300'}`} />
                ))}
                <span className="text-[10px] text-slate-400 ml-1.5 uppercase tracking-wider font-medium">recent</span>
            </div>
        </div>
    )
}

// ── Spaced repetition: weak topics ───────────────────────────────────────────
