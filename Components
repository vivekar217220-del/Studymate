import { useEffect } from 'react'
import { useStreak, useSessions, useQuizScores } from '../hooks/useStudyTracker'

// ── Mini bar chart for last 7 days ────────────────────────────────────────────
function WeekChart({ data }) {
    const maxMins = Math.max(...data.map(d => d.mins), 1)
    return (
        <div className="flex items-end gap-2 h-24">
            {data.map((d, i) => (
                <div key={i} className="flex-1 flex flex-col items-center gap-2">
                    <div className="w-full relative flex items-end justify-center" style={{ height: '70px' }}>
                        <div
                            className={`w-full rounded-sm transition-all duration-500 ${d.mins > 0 ? 'bg-slate-800' : 'bg-slate-100'
                                }`}
                            style={{ height: `${Math.max((d.mins / maxMins) * 70, d.mins > 0 ? 4 : 2)}px` }}
                            title={`${d.mins} min`}
                        />
                    </div>
                    <span className="text-[10px] text-slate-500 font-medium uppercase tracking-wider">{d.label}</span>
                </div>
            ))}
        </div>
    )
}

// ── Streak card ─────────────────────────────────────────────────────────
function StreakCard({ streak }) {
    const isActiveToday = streak.lastDate === new Date().toISOString().slice(0, 10)
    return (
        <div className="rounded-lg p-5 border bg-white border-slate-200 flex flex-col gap-2">
            <div className="flex items-center justify-between">
                <span className="text-[11px] text-slate-500 font-semibold uppercase tracking-wider">Study Streak</span>
                <span className="text-lg opacity-80">{isActiveToday ? '🔥' : '⏸️'}</span>
            </div>
            <p className="text-3xl font-semibold tracking-tight text-slate-900">
                {streak.count}<span className="text-sm font-normal text-slate-500 ml-1.5">days</span>
            </p>
            <p className="text-xs text-slate-500">
                {isActiveToday ? 'Active today' : 'Open a subject to continue'}
            </p>
            {streak.longestStreak > 0 && (
                <p className="text-xs text-slate-600 font-medium mt-1">Best: <span className="text-slate-900">{streak.longestStreak} days</span></p>
            )}
