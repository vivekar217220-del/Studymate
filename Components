            <div className="flex-1 grid grid-cols-3 gap-5 min-h-0">
                {columns.map(col => (
                    <div key={col.id} className={`${col.color} border border-slate-200 rounded p-4 flex flex-col h-full`}>
                        <div className="flex items-center justify-between mb-4 border-b border-slate-200 pb-2">
                            <h4 className="text-slate-700 font-semibold text-xs tracking-wider uppercase">{col.title}</h4>
                            <span className="bg-white px-2 py-0.5 rounded text-[10px] font-semibold text-slate-500 border border-slate-200">{tasks.filter(t => t.status === col.id).length}</span>
                        </div>
                        <div className="flex-1 overflow-y-auto space-y-2.5 pb-2 pr-1">
                            {tasks.filter(t => t.status === col.id).map(t => (
                                <div key={t.id} className="bg-white p-3.5 rounded border border-slate-200 shadow-sm hover:border-slate-300 transition-colors group flex flex-col">
                                    <p className={`text-sm font-medium mb-4 leading-snug ${col.id === 'done' ? 'text-slate-400 line-through' : 'text-slate-800'}`}>{t.text}</p>
                                    <div className="flex justify-between items-center mt-auto">
                                        <button onClick={() => deleteTask(t.id)} className="text-slate-400 hover:text-slate-700 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity">Remove</button>
                                        <div className="flex gap-1 ml-auto">
                                            {col.id !== 'todo' && <button onClick={() => moveTask(t.id, col.id === 'done' ? 'progress' : 'todo')} className="w-7 h-7 rounded bg-white hover:bg-slate-50 text-slate-600 flex items-center justify-center font-bold text-xs border border-slate-200 transition-colors" aria-label="Move left">←</button>}
                                            {col.id !== 'done' && <button onClick={() => moveTask(t.id, col.id === 'todo' ? 'progress' : 'done')} className="w-7 h-7 rounded bg-white hover:bg-slate-50 text-slate-600 flex items-center justify-center font-bold text-xs border border-slate-200 transition-colors" aria-label="Move right">→</button>}
                                        </div>
                                    </div>
                                </div>
                            ))}
                            {tasks.filter(t => t.status === col.id).length === 0 && (
                                <div className="h-20 border border-dashed border-slate-200 rounded flex items-center justify-center text-slate-400 text-xs">
                                    No tasks here
                                </div>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    )
}

