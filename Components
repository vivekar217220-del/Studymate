import { useState, useEffect, useRef } from 'react'

// ─── Pomodoro Timer ──────────────────────────────────────────────────────────
function PomodoroTimer() {
    const FOCUS_TIME = 25 * 60
    const BREAK_TIME = 5 * 60

    const [mode, setMode] = useState('focus') // 'focus' | 'break'
    const [timeLeft, setTimeLeft] = useState(FOCUS_TIME)
    const [isActive, setIsActive] = useState(false)
    const [sessionsCompleted, setSessionsCompleted] = useState(0)
    
    // For local analytics
    const [totalDeepWork, setTotalDeepWork] = useState(parseInt(localStorage.getItem('studymate_deepwork') || '0', 10))

    useEffect(() => {
        let interval = null
        if (isActive && timeLeft > 0) {
            interval = setInterval(() => {
                setTimeLeft(time => time - 1)
            }, 1000)
        } else if (timeLeft === 0) {
            // Timer complete
            setIsActive(false)
            if (mode === 'focus') {
                const newTotal = totalDeepWork + 25
                setTotalDeepWork(newTotal)
                localStorage.setItem('studymate_deepwork', newTotal.toString())
                setSessionsCompleted(s => s + 1)
                setMode('break')
                setTimeLeft(BREAK_TIME)
                new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3').play().catch(()=>{}) // gentle chime
                alert("Focus session complete! Time for a 5-minute break.")
            } else {
                setMode('focus')
                setTimeLeft(FOCUS_TIME)
                alert("Break is over! Time to focus.")
            }
        }
        return () => clearInterval(interval)
    }, [isActive, timeLeft, mode, totalDeepWork])

    const toggleTimer = () => setIsActive(!isActive)
    const resetTimer = () => {
        setIsActive(false)
        setTimeLeft(mode === 'focus' ? FOCUS_TIME : BREAK_TIME)
    }

    const mins = Math.floor(timeLeft / 60).toString().padStart(2, '0')
    const secs = (timeLeft % 60).toString().padStart(2, '0')

    const p = ((mode === 'focus' ? FOCUS_TIME : BREAK_TIME) - timeLeft) / (mode === 'focus' ? FOCUS_TIME : BREAK_TIME) * 100

    return (
        <div className="bg-white rounded-lg p-6 border border-slate-200 shadow-sm flex flex-col h-[600px] font-sans">
            <h3 className="text-slate-900 font-semibold text-base mb-1">Session Timer</h3>
            <p className="text-slate-500 text-xs mb-8">Maintain focus intervals for deep work</p>
            
            <div className="flex justify-center gap-2 mb-8">
                <button onClick={() => { setMode('focus'); setIsActive(false); setTimeLeft(FOCUS_TIME) }}
                    className={`px-5 py-1.5 rounded text-xs font-semibold tracking-wide transition-colors ${mode === 'focus' ? 'bg-slate-800 text-white shadow-sm' : 'bg-slate-100 text-slate-500 hover:bg-slate-200'}`}>
                    Focus (25m)
                </button>
                <button onClick={() => { setMode('break'); setIsActive(false); setTimeLeft(BREAK_TIME) }}
                    className={`px-5 py-1.5 rounded text-xs font-semibold tracking-wide transition-colors ${mode === 'break' ? 'bg-slate-400 text-white shadow-sm' : 'bg-slate-100 text-slate-500 hover:bg-slate-200'}`}>
                    Break (5m)
                </button>
            </div>

            <div className="flex-1 flex flex-col items-center justify-center">
                <div className="relative w-48 h-48 flex items-center justify-center mb-10">
                    <svg className="w-full h-full absolute transform -rotate-90">
                        <circle cx="96" cy="96" r="88" className="stroke-slate-100" strokeWidth="4" fill="none" />
                        <circle cx="96" cy="96" r="88" className={`transition-all duration-1000 ease-linear ${mode === 'focus' ? 'stroke-slate-800' : 'stroke-slate-400'}`} 
                            strokeWidth="4" fill="none" strokeLinecap="round"
                            style={{ strokeDasharray: 2 * Math.PI * 88, strokeDashoffset: (2 * Math.PI * 88) * (1 - p / 100) }} />
                    </svg>
                    <div className="text-center z-10 flex flex-col items-center">
                        <div className="text-5xl font-semibold text-slate-900 tracking-tighter tabular-nums">{mins}:{secs}</div>
                        <div className="text-[10px] font-medium mt-1 tracking-widest text-slate-400 uppercase">{mode === 'focus' ? 'Focusing' : 'Resting'}</div>
                    </div>
                </div>

                <div className="flex gap-3 w-full max-w-[240px]">
                    <button onClick={toggleTimer} className={`flex-1 py-3 rounded text-white font-medium text-sm shadow-sm transition-colors ${isActive ? 'bg-slate-500 hover:bg-slate-600' : 'bg-slate-900 hover:bg-black'}`}>
                        {isActive ? 'Pause' : 'Start Timer'}
                    </button>
                    <button onClick={resetTimer} className="w-12 py-3 bg-white border border-slate-200 hover:bg-slate-50 text-slate-600 rounded transition flex items-center justify-center font-bold" aria-label="Reset Timer">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                    </button>
                </div>
            </div>

            <div className="mt-8 grid grid-cols-2 gap-4 border-t border-slate-100 pt-6">
                <div className="text-center">
                    <p className="text-xl font-semibold text-slate-800 leading-none">{sessionsCompleted}</p>
                    <p className="text-[10px] font-medium text-slate-500 uppercase tracking-widest mt-1.5">Sessions</p>
                </div>
                <div className="text-center">
                    <p className="text-xl font-semibold text-slate-800 leading-none">{totalDeepWork}m</p>
                    <p className="text-[10px] font-medium text-slate-500 uppercase tracking-widest mt-1.5">Total Focus</p>
                </div>
            </div>
        </div>
    )
}

