function KanbanBoard() {
    const [tasks, setTasks] = useState(() => {
        try { return JSON.parse(localStorage.getItem('studymate_tasks') || '[]') } 
        catch { return [] }
    })
    const [newTask, setNewTask] = useState('')

    useEffect(() => {
        localStorage.setItem('studymate_tasks', JSON.stringify(tasks))
    }, [tasks])

    const addTask = (e) => {
        e.preventDefault()
        if (!newTask.trim()) return
        setTasks(prev => [...prev, { id: Date.now().toString(), text: newTask.trim(), status: 'todo' }])
        setNewTask('')
    }

    const moveTask = (id, newStatus) => {
        setTasks(prev => prev.map(t => t.id === id ? { ...t, status: newStatus } : t))
    }

    const deleteTask = (id) => {
        setTasks(prev => prev.filter(t => t.id !== id))
    }

    const columns = [
        { id: 'todo', title: 'To Do', color: 'bg-slate-50' },
        { id: 'progress', title: 'In Progress', color: 'bg-slate-50' },
        { id: 'done', title: 'Completed', color: 'bg-slate-50' }
